# ── AI ────────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
# Model to use. Default: deepseek-chat. Set to any valid DeepSeek model name.
DEEPSEEK_MODEL=deepseek-chat

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── Database (VPS PostgreSQL) ─────────────────────────────────────────────────
# Required for persistence. Point to your VPS PostgreSQL instance.
# Example: postgresql://user:password@your-vps-ip:5432/apexdev
DATABASE_URL=
# Set DB_SSL=true if your VPS requires SSL connections
DB_SSL=false

# ── Authentication — single-user ──────────────────────────────────────────────
AUTH_USERNAME=mac_david
AUTH_PASSWORD=@Davidluiz4life
# JWT signing secret — use a long random string in production
JWT_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
# Comma-separated allowed origins in production
ALLOWED_ORIGINS=

# ── Deployment ────────────────────────────────────────────────────────────────
PM2_SERVICE_NAME=apex-dev
DOCKER_COMPOSE_FILE=docker-compose.yml
